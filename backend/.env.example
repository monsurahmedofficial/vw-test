PORT=5000
JWT_SECRET=your_super_secret_jwt_key_change_this

# Database — set DATABASE_URL for Supabase/PostgreSQL, or USE_SQLITE=true for local dev
USE_SQLITE=true
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase Storage (for proof photo uploads in production)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Legacy MySQL (not needed if using Supabase)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=vw_crm

SMTP_HOST=mail.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM=Vapor World CRM <noreply@yourdomain.com>

FRONTEND_URL=http://localhost:5173
